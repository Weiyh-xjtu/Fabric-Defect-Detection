# ═══════════════════════════════════════════════════════
# 基于 YOLOv11 的目标检测智能体平台 — 环境变量配置
# ═══════════════════════════════════════════════════════

# ── OpenAI API 配置（根据项目需求进行修改使用） ─────────────────────────
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Qwen API 配置 ───────────────────────────────────
QWEN_API_KEY=sk-your-qwen-api-key
QWEN_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
# Qwen 兼容模式 API（用于 LangChain OpenAI 客户端）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ── RAG / Embedding 独立配置 ────────────────────────
# Embedding 可以使用与聊天模型不同的服务、URL 和密钥。
# 默认示例使用通义千问 text-embedding-v3，对应 1024 维。
# 如果使用 OpenAI text-embedding-3-small，请将 EMBEDDING_DIM 改为 1536。
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# 知识文档分块大小、相邻分块重叠字符数、默认返回结果数量
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3

# ── 数据库配置 ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your-database-name
DB_USER=your-database-username
DB_PASSWORD=your-database-password

# ── Redis 配置 ──────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# 开发环境：本地 Docker
DATABASE_URL=postgresql://your-database-username:your-database-password@localhost:5432/your-database-name
# 生产环境：取消下一行的注释并注释掉上面的行
# DATABASE_URL=postgresql://your-database-username:your-secure-password@your-host:5432/your-database-name

# ── 本地 LLM 配置（可选）────────────────────
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b


# ── Redis 配置 ───────────────────────────────────────
# 开发环境：本地 Docker
REDIS_URL=redis://localhost:6379/0
# 生产环境：取消下一行的注释并注释掉上面的行
# REDIS_URL=redis://:your-redis-password@your-redis-host:6379/0

# ── MinIO 对象存储配置 ───────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=rsod-images
MINIO_SECURE=false
# 避免远端 MinIO 不可达时单次连接等待数分钟
MINIO_CONNECT_TIMEOUT_SECONDS=5
MINIO_READ_TIMEOUT_SECONDS=600
MINIO_RETRY_TOTAL=2

# 浏览器通过 /api/files/{token} 访问私有 MinIO 文件，默认有效期 7 天
FILE_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── JWT 认证配置 ─────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=35
REFRESH_COOKIE_NAME=rsod_refresh_token
# 本地 HTTP 开发环境为 false；生产 HTTPS 环境应设为 true
REFRESH_COOKIE_SECURE=false

# ── 应用配置 ─────────────────────────────────────────
APP_NAME=RSOD Agent Platform
APP_VERSION=0.1.0
APP_DEBUG=true
LOG_LEVEL=INFO
# 将 YOLO 评估/导出放入独立进程，避免阻塞 Web 请求
MODEL_TASK_PROCESS_ISOLATION=true

# ── CORS 配置 ────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
