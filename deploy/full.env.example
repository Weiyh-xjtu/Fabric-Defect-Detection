# FIRESIGHT 全容器化部署环境变量模板
# 复制到仓库根目录的 .env 并填入真实值：
#   cp deploy/full.env.example .env
# 强随机密钥生成：openssl rand -hex 32

# ── 站点 ────────────────────────────────────────────
# 域名（不带 https://）。Caddy 自动签发 HTTPS 证书，
# 要求 DNS A 记录已指向服务器且 80/443 对公网开放。
# 留空则以纯 HTTP 跑在 80 端口（内网/测试用，此时下面
# REFRESH_COOKIE_SECURE 需改为 false）。
DOMAIN=your-domain.example.com
REFRESH_COOKIE_SECURE=true

# ── PostgreSQL ──────────────────────────────────────
POSTGRES_DB=rsod_agent
POSTGRES_USER=rsod_admin
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── MinIO ───────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MINIO_BUCKET=rsod-images

# ── JWT ─────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32

# ── 聊天大模型（OpenAI 兼容 / Qwen）─────────────────
QWEN_API_KEY=sk-your-real-qwen-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ── 知识库 Embedding ────────────────────────────────
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024
