# 基础设施（docker compose）生产密码模板
# 部署时复制到项目根目录的 .env（与 docker-compose.yml 同级）：
#   cp deploy/infra.env.prod.example .env
# 这些值必须与 backend/.env 里的对应项一致。

POSTGRES_DB=rsod_agent
POSTGRES_USER=rsod_admin
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
